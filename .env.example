# Local Mishka / ransomeye-core development (see README.md).
# Copy to .env and adjust; never commit real secrets.

# PostgreSQL: prefer a single keyword or postgres:// DSN (sslmode=verify-full, host=127.0.0.1).
# Core honors user/password/dbname from POSTGRES_DSN; PGPASSWORD is not required when password is in the DSN.
# Dev mode may add sslrootcert/sslcert/sslkey paths automatically from configs/db-certs.
POSTGRES_DSN=

# Required for core: RANSOMEYE_MASTER_KEY (64 hex), RANSOMEYE_SOC_ADDR (e.g. 127.0.0.1:8443).
# Optional (omit for 3-service Mishka): RANSOMEYE_AI_ADDR, RANSOMEYE_SINE_ADDR, RANSOMEYE_INTEL_ADDR,
# and DPI plane (all three: RANSOMEYE_DPI_PUBLIC_KEY_PATH, RANSOMEYE_DPI_AGENT_ID, RANSOMEYE_DPI_TENANT_ID).
# RANSOMEYE_DPI_CONTROL_DISABLED=true suppresses DPI control unix traffic when a probe is not deployed.

# Optional verification harness overrides for DB-backed authority tests.
# These are used by scripts/authority_db_env.sh and scripts/run_authority_db_tests.sh
# when POSTGRES_DSN is not already exported.
# MISHKA_TEST_DB_HOST=127.0.0.1
# MISHKA_TEST_DB_PORT=5432
# MISHKA_TEST_DB_USER=ransomeye
# MISHKA_TEST_DB_PASSWORD=dev_password
# MISHKA_TEST_DB_NAME=ransomeye_core
# MISHKA_TEST_DB_SSLROOTCERT=/home/you/ransomeye-source/configs/db-certs/ca.crt
# MISHKA_TEST_DB_SSLCERT=/home/you/ransomeye-source/configs/db-certs/client.crt
# MISHKA_TEST_DB_SSLKEY=/home/you/ransomeye-source/configs/db-certs/client.key

# Optional: explicit migrations directory for db-bootstrap (default: /opt/ransomeye/core/migrations/).
# RANSOMEYE_MIGRATIONS_DIR=/home/you/ransomeye-source/core/migrations/

# Air-gap capability (PRD-19): file-based resolv.conf + route table checks only — no live outbound dials.
# RANSOMEYE_AIR_GAP_MODE=enforced   # default when unset: fail closed outside DEV if default route / external resolver
# RANSOMEYE_AIR_GAP_MODE=preflight  # always record posture; never fatal (lab / internet-connected dev)
# RANSOMEYE_AIR_GAP_MODE=off        # skip checks; posture "disabled"
# RANSOMEYE_DISABLE_AIR_GAP_CHECKS=true  # lab bypass; posture "bypassed_for_lab"; health shows degraded

# Replay DB tests (PRD-15): same POSTGRES_DSN + PGSSL* as authority lane — see scripts/authority_db_env.sh --export
